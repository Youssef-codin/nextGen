        "type": "object",
        "required": ["run_id", "test_start", "test_end"],
        "title": "BacktestRequest"
      },
      "BacktestResponse": {
        "properties": {
          "backtest_id": {
            "type": "string",
            "title": "Backtest Id"
          },
          "run_id": {
            "type": "string",
            "title": "Run Id"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "initial_capital": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Initial Capital"
          },
          "account_value": {
            "anyOf": [
              {
                "items": {
                  "type": "number"
