  "components": {
    "schemas": {
      "BacktestRequest": {
        "properties": {
          "run_id": {
            "type": "string",
            "title": "Run Id"
          },
          "test_start": {
            "type": "string",
            "title": "Test Start"
          },
          "test_end": {
            "type": "string",
            "title": "Test End"
          },
          "initial_capital": {
            "type": "number",
            "title": "Initial Capital",
            "default": 1000000.0
